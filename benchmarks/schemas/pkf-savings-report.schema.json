{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://token-atlas.local/schemas/pkf-savings-report.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "benchmark",
    "benchmark_spec",
    "phases_selected",
    "baseline",
    "target",
    "environment",
    "metrics",
    "runs",
    "errors"
  ],
  "properties": {
    "schema_version": {"const": 9},
    "run_id": {"type": "string"},
    "benchmark": {"type": "string"},
    "benchmark_spec": {
      "type": "object",
      "required": ["sha256", "schema_version"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "schema_version": {"const": 1}
      }
    },
    "phases_selected": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["retrieval", "mutation", "post_mutation", "closeout"]}
    },
    "baseline": {
      "type": "object",
      "required": ["runtime_sha256"],
      "properties": {
        "path": {"type": "string"},
        "runtime_sha256": {"type": "string"},
        "created_at": {"type": ["string", "null"]}
      }
    },
    "target": {"type": "object"},
    "environment": {"type": "object"},
    "metrics": {"type": "object"},
    "runs": {"type": "array"},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
