{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://token-atlas.local/schemas/pkf-baseline-manifest.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "target",
    "runtime_sha256",
    "source_sha256",
    "skill_sha256",
    "generation",
    "validation_status",
    "runtime_inventory",
    "semantic_acceptance"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "created_at": {"type": "string"},
    "target": {
      "type": "object",
      "required": ["repository_id", "commit", "tree"],
      "properties": {
        "repository_id": {"type": "string"},
        "commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "tree": {"type": "string", "pattern": "^[a-f0-9]{40}$"}
      },
      "additionalProperties": false
    },
    "runtime_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "skill_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "generation": {
      "type": "object",
      "required": ["initialization", "completeness_review"],
      "properties": {
        "initialization": {"$ref": "#/$defs/pass"},
        "completeness_review": {"$ref": "#/$defs/pass"}
      },
      "additionalProperties": false
    },
    "validation_status": {"const": "passed"},
    "runtime_inventory": {
      "type": "object",
      "required": ["module_ids", "module_count", "leaf_paths", "leaf_count"],
      "properties": {
        "module_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "module_count": {"type": "integer", "minimum": 1},
        "leaf_paths": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
        "leaf_count": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "semantic_acceptance": {
      "type": "object",
      "required": ["status", "scope", "task_relevance_proven"],
      "properties": {
        "status": {"const": "model_review_completed"},
        "scope": {"type": "string"},
        "task_relevance_proven": {"const": false}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "pass": {
      "type": "object",
      "required": ["executor", "role", "model", "reasoning_effort", "returncode", "duration_ms", "attempt"],
      "properties": {
        "executor": {"type": "string"},
        "role": {"type": "string"},
        "model": {"type": "string"},
        "reasoning_effort": {"type": "string"},
        "returncode": {"const": 0},
        "duration_ms": {"type": "integer", "minimum": 0},
        "attempt": {"type": "integer", "minimum": 1}
      }
    }
  }
}
