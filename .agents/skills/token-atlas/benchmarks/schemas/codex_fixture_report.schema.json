{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Token Atlas Codex Fixture Report",
  "type": "object",
  "required": [
    "fixture",
    "status",
    "selected_modules",
    "generated_modules",
    "required_docs",
    "source_targets",
    "targeted_commands",
    "fallback_search",
    "forbidden_loads",
    "warnings",
    "errors",
    "token_impact",
    "exit_behavior",
    "evidence"
  ],
  "properties": {
    "fixture": { "type": "string" },
    "status": { "type": "string", "enum": ["passed", "warning", "failed"] },
    "selected_modules": { "type": "array", "items": { "type": "string" } },
    "selected_routes": { "type": "array", "items": { "type": "string" } },
    "unique_leaf_count": { "type": "integer", "minimum": 0 },
    "requirement_count": { "type": "integer", "minimum": 0 },
    "covered_requirement_count": { "type": "integer", "minimum": 0 },
    "conflicting_requirement_ids": { "type": "array", "items": { "type": "string" } },
    "uncovered_requirement_ids": { "type": "array", "items": { "type": "string" } },
    "unresolved_leaf_paths": { "type": "array", "items": { "type": "string" } },
    "redundant_leaf_paths": { "type": "array", "items": { "type": "string" } },
    "coverage_status": { "type": "string", "enum": ["complete", "incomplete", "unknown"] },
    "irredundancy_status": { "type": "string", "enum": ["irredundant", "redundant", "invalid", "unknown"] },
    "estimated_route_tokens": { "type": "integer", "minimum": 0 },
    "generated_modules": { "type": "array", "items": { "type": "string" } },
    "required_docs": { "type": "array", "items": { "type": "string" } },
    "source_targets": { "type": "array", "items": { "type": "string" } },
    "targeted_commands": { "type": "array", "items": { "type": "string" } },
    "fallback_search": {
      "type": "object",
      "required": ["required", "reason"],
      "properties": {
        "required": { "type": "boolean" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "forbidden_loads": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } },
    "token_impact": {
      "type": "object",
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "exit_behavior": {
      "type": "object",
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "evidence": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
